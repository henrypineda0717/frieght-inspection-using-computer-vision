APP_NAME="Container Inspection System V3"
APP_VERSION="3.0.0"
DEBUG=False

HOST=0.0.0.0
PORT=8001

DATABASE_URL="sqlite:///./inspections.db"

GENERAL_MODEL_PATH = "backend/yolov8n.pt"
YOLOE_REAR_MODEL_PATH="container_front.pt"
RT_DETR_DEFECT_MODEL_PATH="checkpoint_best_ema.pth"

OCR_MODEL_TYPE="paddle_v4"
OCR_GPU=True

GENERAL_MODEL_CONFIDENCE=0.25
REAR_CONFIDENCE=0.15
DEFECT_CONFIDENCE=0.15

REAR_IMGSZ=640
INTERIOR_IMGSZ=640

USE_GPU=True
USE_FP16=True

RETENTION_DAYS=90
MAX_UPLOAD_SIZE=104857600

VIDEO_SAMPLE_INTERVAL=2.0
MAX_ANALYZED_FRAMES=40
VIDEO_BATCH_SIZE=50

CORS_ORIGINS=["*"]